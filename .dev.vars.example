# =============================================================================
# better-prode — Development Environment Variables
# =============================================================================
# Copy this file to .dev.vars (gitignored) and fill in your credentials.
# For local Cloudflare Workers dev (wrangler dev), Wrangler reads .dev.vars.
# For local Vite dev (npm run dev), you can also use a .env file.
#
# Variables marked [EXTERNAL CRED] require accounts / external services.
# Variables marked [CLAUDE-GENERATED] are pre-filled and ready to copy.
#
# IMPORTANT: Never commit .dev.vars — it contains real secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# Database — Turso / libSQL
# -----------------------------------------------------------------------------

# [EXTERNAL CRED] Your Turso database URL.
# Production: libsql://<db-name>-<org>.turso.io
# Local dev:  file:./local.db  (creates a SQLite file in the project root)
# Tests:      :memory:          (in-memory, wiped after each process)
TURSO_DATABASE_URL=file:./local.db

# [EXTERNAL CRED] Turso auth token (not needed for local file: URLs).
# Get it at: https://app.turso.tech → your database → Generate Token
TURSO_AUTH_TOKEN=


# -----------------------------------------------------------------------------
# Google OAuth — Better Auth
# -----------------------------------------------------------------------------

# [EXTERNAL CRED] Google OAuth 2.0 credentials.
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI to add: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Better Auth session signing secret
# -----------------------------------------------------------------------------

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=REPLACE_WITH_GENERATED_SECRET

# Better Auth base URL — used for OAuth callbacks and redirects.
# Local dev: http://localhost:3000
# Production: your deployed Workers origin, e.g. https://better-prode.workers.dev
BETTER_AUTH_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Admin access
# -----------------------------------------------------------------------------

# Comma-separated user IDs allowed to settle match results (the admin
# apply-result endpoint). Empty = no admins (fail-closed — the endpoint is
# effectively disabled). After your first login, set this to your own user id.
# Example: ADMIN_USER_IDS=user_abc123,user_def456
ADMIN_USER_IDS=


# -----------------------------------------------------------------------------
# Football data provider (ResultSource adapter — deploy dependency)
# -----------------------------------------------------------------------------

# [EXTERNAL CRED] Football-Data.org API token (free tier available).
# Docs: https://www.football-data.org/documentation/quickstart
# The provider is isolated behind the ResultSource port; swap without changing domain.
FOOTBALL_DATA_API_TOKEN=

# [EXTERNAL CRED] API-Football key (alternative provider, if chosen instead).
# Docs: https://www.api-football.com/documentation-v3
API_FOOTBALL_KEY=


# -----------------------------------------------------------------------------
# Web Push (VAPID) — Reminders (PR 5)
# -----------------------------------------------------------------------------

# Generate both keys together with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=REPLACE_WITH_GENERATED_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=REPLACE_WITH_GENERATED_VAPID_PRIVATE_KEY

# [EXTERNAL CRED] Your registered mailto: or https: subject for VAPID.
# Used by push services to contact you about abuse or issues.
# Example: mailto:you@example.com
VAPID_SUBJECT=mailto:admin@better-prode.app
